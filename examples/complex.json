{
  "title": "Loopmark implementation questions",
  "description": "Questions for a cloud AI Agent input handoff.",
  "groups": [
    {
      "id": "product",
      "title": "Product direction",
      "description": "Clarify what the agent should optimize for.",
      "fields": [
        {
          "id": "positioning",
          "label": "How should the agent describe this product?",
          "type": "text",
          "multiline": true,
          "default": "A cloud human-input handoff for AI Agents."
        },
        {
          "id": "include_approval",
          "label": "Should this include approval or permission semantics?",
          "type": "choice",
          "mode": "single",
          "default": "No",
          "options": ["No", "Yes"]
        }
      ]
    },
    {
      "id": "implementation",
      "title": "Implementation",
      "fields": [
        {
          "id": "scope",
          "label": "Which capabilities belong in v1?",
          "type": "choice",
          "mode": "multiple",
          "default": ["stdin JSON", "Cloud fill URL", "collect command"],
          "options": ["stdin JSON", "Cloud fill URL", "collect command", "Paper Trail design"]
        },
        {
          "id": "priority",
          "label": "Rank the implementation priorities.",
          "type": "choice",
          "mode": "ranking",
          "options": [
            {
              "label": "Input validation",
              "description": "Errors should tell the agent what is wrong and how to fix it."
            },
            "CLI lifecycle",
            "Paper Trail UI"
          ]
        },
        {
          "id": "api_key",
          "label": "Optional API key for testing",
          "type": "text",
          "secret": true
        }
      ]
    }
  ]
}
