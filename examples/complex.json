{
  "title": "Loopmark implementation questions",
  "description": "Questions for a local AI Agent input gate.",
  "groups": [
    {
      "id": "product",
      "title": "Product direction",
      "description": "Clarify what the agent should optimize for.",
      "fields": [
        {
          "id": "positioning",
          "label": "How should the agent describe this product?",
          "type": "text",
          "multiline": true,
          "format": "markdown",
          "required": true,
          "default": "A local human-input gate for AI Agents."
        },
        {
          "id": "include_approval",
          "label": "Should this include approval or permission semantics?",
          "type": "choice",
          "mode": "single",
          "required": true,
          "default": "No",
          "options": ["No", "Yes"]
        }
      ]
    },
    {
      "id": "implementation",
      "title": "Implementation",
      "fields": [
        {
          "id": "scope",
          "label": "Which capabilities belong in v1?",
          "type": "choice",
          "mode": "multiple",
          "required": true,
          "default": ["stdin JSON", "Local web UI", "stdout JSON"],
          "options": ["stdin JSON", "Local web UI", "stdout JSON", "Paper Trail design"]
        },
        {
          "id": "priority",
          "label": "Rank the implementation priorities.",
          "type": "choice",
          "mode": "ranking",
          "required": true,
          "options": [
            {
              "label": "Input validation",
              "description": "Errors should tell the agent what is wrong and how to fix it."
            },
            "CLI lifecycle",
            "Paper Trail UI"
          ]
        },
        {
          "id": "api_key",
          "label": "Optional API key for local testing",
          "type": "text",
          "secret": true,
          "required": false
        }
      ]
    }
  ]
}
